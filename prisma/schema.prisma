generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id            Int      @id @default(autoincrement())

  firstName     String
  lastName      String
  email         String   @unique
  passwordHash  String

  isActive      Boolean  @default(true)

  roleId        Int
  role          Role     @relation(fields: [roleId], references: [id])

  createdCases  Case[]   @relation("CaseCreator")
  assignedCases Case[]   @relation("CaseAssignee")

  // Cases this user collaborates on (many-to-many assignees).
  caseAssignments Case[] @relation("CaseAssignees")

writtenCases Case[] @relation("CaseWriter")
editedCases  Case[] @relation("CaseEditor")

  // Cases this user has marked as "not a duplicate".
  dismissedDuplicates Case[] @relation("NotDuplicateBy")

  // AI report analyses this user has run.
  caseAnalyses  CaseAnalysis[] @relation("AnalysisAuthor")

  // Activity Timeline
  activities    CaseActivity[]

  uploadedMedia CaseMedia[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([roleId])
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?

  users       User[]
  permissions RolePermission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?

  roles       RolePermission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("permissions")
}

model RolePermission {
  roleId       Int
  permissionId Int

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Case {
  id              Int        @id @default(autoincrement())

  // Case Identity
  caseNumber      String?

  // Duplicate Tracking
  isDuplicate     Boolean    @default(false)

  // Manual override: a user has reviewed the duplicate warning and confirmed
  // this case is NOT a duplicate. Cases flagged here are excluded from
  // duplicate-group detection entirely, so they stop being flagged and stop
  // causing the case they were matched against to be flagged.
  notDuplicate    Boolean    @default(false)
  notDuplicateAt  DateTime?
  notDuplicateById Int?
  notDuplicateBy  User?      @relation("NotDuplicateBy", fields: [notDuplicateById], references: [id])

  duplicateOfId   Int?
  duplicateOf     Case?      @relation("DuplicateCase", fields: [duplicateOfId], references: [id])
  duplicates      Case[]     @relation("DuplicateCase")

  // Submission Info
  dateSubmitted   DateTime   @default(now())
  submittedVia    String?
  caseNotes       String?

  // Agency Info
  policeAgency    String?
  enteredBy       String?

  agencyId        Int?
  agency          Agency?    @relation(fields: [agencyId], references: [id])

  // Incident Info
  incidentDate    DateTime?
  location        String?
  suspectName     String?
  age             Int?
  incidentSummary String?

  // Case Details
  title           String?
  description     String?

  // Status
  statusId        Int
  status          Status     @relation(fields: [statusId], references: [id])

  // Media
  mediaType       String?
  caseGoogleDriveLink  String?

  // Completion
  dateCompleted   DateTime?
  potential       String?
 caseReference   String?
 
    reminderNote    String?
  reminderDate   DateTime?


  // Assignment
  createdById     Int
  createdBy       User       @relation("CaseCreator", fields: [createdById], references: [id])

  assignedToId    Int?
  assignedTo      User?      @relation("CaseAssignee", fields: [assignedToId], references: [id])

  assignees       User[]     @relation("CaseAssignees")

  dateAssigned        DateTime?

  writerId            Int?
  writer              User?     @relation("CaseWriter", fields: [writerId], references: [id])

  scriptStatusId      Int?
  scriptStatus        Status?   @relation("CaseScriptStatus", fields: [scriptStatusId], references: [id])

  editorId            Int?
  editor              User?     @relation("CaseEditor", fields: [editorId], references: [id])

  editorStatusId      Int?
  editorStatus        Status?   @relation("CaseEditorStatus", fields: [editorStatusId], references: [id])

  // The status the case held immediately before it was voided, so "Restore"
  // can return it to where it was rather than a fixed stage.
  preVoidStatusId     Int?
  preVoidStatus       Status?   @relation("CasePreVoidStatus", fields: [preVoidStatusId], references: [id])

  editorPaid          Boolean   @default(false)
  editorPaidDate      DateTime?

  researcherPaid      Boolean   @default(false)
  researcherPaidDate  DateTime?

  // Media
  media           CaseMedia[]

  // AI content analyses (one per run against a report PDF)
  analyses        CaseAnalysis[]

  // Timeline
  activities      CaseActivity[]

  // Audit
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([statusId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([writerId])
  @@index([editorId])
  @@index([editorStatusId])
  @@index([caseNumber])
  @@index([suspectName])
  @@index([duplicateOfId])
  @@index([agencyId])

  @@map("cases")
}

// AI analysis of a case's report PDF. Stored so the result is auditable and
// isn't re-run (and re-paid) each time the case is opened.
model CaseAnalysis {
  id            Int      @id @default(autoincrement())

  caseId        Int
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Which report was analyzed (storage URL + display name).
  fileUrl       String?
  fileName      String?

  // The model used and the parsed overall rating (e.g. "4/5"), for quick display.
  model         String?
  overallRating String?

  // Full formatted analysis text (markdown as returned by the model).
  result        String

  createdById   Int?
  createdBy     User?    @relation("AnalysisAuthor", fields: [createdById], references: [id])

  createdAt     DateTime @default(now())

  @@index([caseId])
  @@map("case_analyses")
}
model CaseActivity {
  id          Int      @id @default(autoincrement())

  caseId      Int
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])

  type        String

  message     String   @db.Text

  createdAt   DateTime @default(now())

  @@index([caseId])
  @@index([userId])

  @@map("case_activities")
}
model Agency {
  id          Int      @id @default(autoincrement()) @map("agency_id")
  name        String   @unique @map("agency_name")
  description String?  @map("agency_description")
  allowed     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  // Cases linked to this agency
  cases       Case[]

  @@map("agencies")
}

model Status {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  label       String
  color       String   @default("gray")
  stage       String?
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

 cases  Case[]
  scriptCases Case[] @relation("CaseScriptStatus")
 editorCases Case[] @relation("CaseEditorStatus")
  preVoidCases Case[] @relation("CasePreVoidStatus")

  @@map("statuses")
}

model CaseMedia {
  id            Int      @id @default(autoincrement())

  caseId        Int
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  uploadedById  Int
  uploadedBy    User     @relation(fields: [uploadedById], references: [id])

  fileName      String
  fileUrl       String
  label         String?
  mediaType     String   // image, video, audio, pdf, document

   isReport      Boolean  @default(false)

  createdAt     DateTime @default(now())

  @@index([caseId])
  @@index([uploadedById])

  @@map("case_media")
}

model IncidentType {
  id          Int      @id @default(autoincrement())
  title       String?
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}